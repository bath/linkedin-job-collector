# SMTP credentials for match / re-auth emails. Copy to .env and fill in.
# .env is gitignored — never commit real credentials.
#
# Gmail: create an App Password at https://myaccount.google.com/apppasswords
# (needs 2-Step Verification on). Use that 16-character password below — NOT
# your normal Google password.

LJC_SMTP_USER=you@gmail.com
LJC_SMTP_PASS=your-16-char-app-password
LJC_EMAIL_TO=you@gmail.com

# Optional overrides (defaults shown):
# LJC_SMTP_HOST=smtp.gmail.com
# LJC_SMTP_PORT=465
# LJC_EMAIL_FROM=you@gmail.com
