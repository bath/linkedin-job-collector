# SMTP credentials for match / re-auth emails. Copy to .env and fill in.
# .env is gitignored — never commit real credentials.
#
# Gmail: create an App Password at https://myaccount.google.com/apppasswords
# (needs 2-Step Verification on). Use that 16-character password below — NOT
# your normal Google password.

LJC_SMTP_USER=you@gmail.com
LJC_SMTP_PASS=your-16-char-app-password
LJC_EMAIL_TO=you@gmail.com

# Optional overrides (defaults shown):
# LJC_SMTP_HOST=smtp.gmail.com
# LJC_SMTP_PORT=465
# LJC_EMAIL_FROM=you@gmail.com

# Digest filter provider. "auto" tries Claude first, then Cursor if Claude fails.
# LJC_DIGEST_PROVIDER=auto
# LJC_DIGEST_TIMEOUT_SECONDS=300
#
# Minimum default models. Override these if smoke tests show quality regressions.
# LJC_CLAUDE_MODEL=haiku
# LJC_CURSOR_MODEL=composer-2.5
#
# Optional command overrides, useful for tests or non-standard installs.
# LJC_CLAUDE_CMD=claude
# LJC_CURSOR_CMD=cursor agent
